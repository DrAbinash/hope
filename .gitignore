# ============================================================
# .gitignore — Hope Hospital ERP
# ============================================================

# Secrets — NEVER commit these
.env
.env.local
.env.production
.env.*.local
*.pem
*.key

# Node dependencies
node_modules/
**/node_modules/

# Build outputs
dist/
**/dist/
artifacts/api-server/dist/
artifacts/hms/dist/

# pnpm
.pnpm-store/
**/.pnpm-store/

# Logs
*.log
logs/
npm-debug.log*
pnpm-debug.log*

# Backup files (generated by pg_dump or manual backups)
backup_pre_*
*.sql.gz
*.dump
backups/
# Only ignore SQL in root (dump files) — NOT migrations or scripts folders
/*.sql

# Editor / OS
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/

# Antigravity / Replit scratch (legacy, not part of this repo)
.gemini/
antigravity/

# Temporary
*.tmp
*.bak
.cache/
tmp/
