# Synology NAS .env Configuration

# App Port (This is the port mapped to the NAS IP, e.g., http://NAS-IP:5000)
APP_PORT=5000

# Database Configuration
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=hospital_erp

# Session Secret (Change this!)
SESSION_SECRET=your_super_secret_session_key_change_me_in_production
