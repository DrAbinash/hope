# ============================================================
# Hope NeuroTrauma & MultiSpeciality Hospital ERP
# Environment Configuration Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# Port exposed on the Synology NAS host (maps to container port 5000)
APP_PORT=5000

# Path to the compiled frontend assets served by Express
SERVE_STATIC_DIR=/app/artifacts/hms/dist

# Session encryption key — use a long random string (min 32 chars)
SESSION_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# ------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------
# Full connection URL used by the application
DATABASE_URL=postgresql://postgres:your_secure_password@postgres:5432/hospital_erp

# Individual credentials used by the postgres container itself
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=hospital_erp

# ------------------------------------------------------------
# Google OAuth (optional — used for staff Google sign-in)
# Leave blank to disable Google login; standard login still works.
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------
# Google Cloud Storage (optional — used for offsite backup uploads)
# Leave blank to use local filesystem storage only.
# ------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=

# ------------------------------------------------------------
# File storage paths (inside the container)
# These are mounted as Docker volumes on Synology.
# Do not change unless you update docker-compose.yml volumes too.
# ------------------------------------------------------------
UPLOADS_DIR=/app/uploads
REPORTS_DIR=/app/reports

# ------------------------------------------------------------
# Storage driver
# "local" = write uploads to LOCAL_UPLOADS_DIR (recommended for Synology)
# "gcs"   = Replit GCS-backed object storage (cloud/Replit only)
# ------------------------------------------------------------
STORAGE_DRIVER=local
LOCAL_UPLOADS_DIR=/app/uploads

# ------------------------------------------------------------
# CORS — comma-separated list of allowed frontend origins.
# Required if the frontend is served from a different port or domain.
# For same-origin deployments (frontend served by Express), leave blank.
# Example: http://192.168.1.100:5000,https://hms.hospital.lan
# ------------------------------------------------------------
ALLOWED_ORIGINS=

# ------------------------------------------------------------
# Logging
# LOG_LEVEL: trace | debug | info | warn | error (default: info)
# ------------------------------------------------------------
LOG_LEVEL=info
